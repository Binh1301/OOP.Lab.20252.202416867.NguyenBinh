<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hust.soict.hedspi.javafx.PainterController"
            prefWidth="640" prefHeight="480"
            padding="8">
    <left>
        <VBox spacing="8"
              prefWidth="USE_COMPUTED_SIZE" prefHeight="USE_COMPUTED_SIZE"
              maxHeight="1.7976931348623157E308">
            <BorderPane.margin>
                <Insets right="8"/>
            </BorderPane.margin>
            <children>
                <Button text="Clear" maxWidth="Infinity" onAction="#clearButtonPressed"/>
            </children>
        </VBox>
    </left>
    <center>
        <Pane fx:id="drawingAreaPane"
              style="-fx-background-color: white;"
              onMouseDragged="#drawingAreaMouseDragged"/>
    </center>
</BorderPane>
